    "test:ci": "ng test --no-watch --no-progress --browsers=ChromeHeadless",
    "lint": "ng lint"
  },
  "dependencies": {
    "@angular/animations": "22.0.5",
    "@angular/common": "22.0.5",
    "@angular/compiler": "22.0.5",
    "@angular/core": "22.0.5",
    "@angular/forms": "22.0.5",
    "@angular/platform-browser": "22.0.5",
    "@angular/platform-browser-dynamic": "22.0.5",
    "@angular/platform-server": "22.0.5",
    "@angular/router": "22.0.5",
    "@angular/ssr": "22.0.5",
    "express": "5.2.1",
    "rxjs": "7.8.2",
    "tslib": "2.6.2",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "22.0.5",
    "@angular/cli": "22.0.5",
    "@angular/compiler-cli": "22.0.5",
    "@types/express": "5.0.6",
    "@types/jasmine": "6.0.0",
    "@types/node": "24.13.3",
    "jasmine-core": "6.3.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.2.0",
    "typescript": "7.0.2"
  }
