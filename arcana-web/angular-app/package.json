{
  "name": "arcana-cloud-angular",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:ssr": "ng build && ng run arcana-cloud-angular:server",
    "serve:ssr": "node dist/server/main.js",
    "watch": "ng build --watch --configuration development",
